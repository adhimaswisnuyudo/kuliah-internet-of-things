# Port server + UI (satu proses)
PORT=5173

# MQTT (sama seperti ESP32 — TCP, bukan WSS)
MQTT_URL=mqtt://broker.hivemq.com:1883
MQTT_SUBSCRIBE="digitech/uts-iot/#"

# SQLite (folder data/ dibuat otomatis)
DB_PATH=./data/uts_history.db

# Telegram — notifikasi HANYA saat mahasiswa pertama kali terdeteksi (topik baru)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
